# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=housemonitor
DB_USER=monitor
DB_PASSWORD=monitor123

# Camera
# To find your webcam device name on Windows, run:
#   ffmpeg -list_devices true -f dshow -i dummy 2>&1
# Copy the exact name shown between quotes, e.g. "Integrated Webcam" or "USB2.0 HD UVC WebCam"
CAMERA_DEVICE=Integrated Webcam
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=10

# Detection
# Minimum seconds between consecutive person-detected notifications (anti-spam)
COOLDOWN_SECONDS=30

# Server
PORT=3000

# Storage
FRAMES_DIR=./frames
SNAPSHOTS_DIR=./snapshots

# Cleanup: delete frames older than this many hours (default 48h = 2 days)
FRAME_RETENTION_HOURS=48
