# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=housemonitor
DB_USER=monitor
DB_PASSWORD=your_password_here

# Camera
# To find your webcam device name on Windows, run:
#   ffmpeg -list_devices true -f dshow -i dummy 2>&1
# Copy the exact name shown between quotes, e.g. "Integrated Webcam" or "USB2.0 HD UVC WebCam"
CAMERA_DEVICE=Your Webcam Name
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# How many seconds without a detection before presence window ends (creates new event on re-entry)
ABSENCE_THRESHOLD_SECONDS=60

# Server
# Change to 8080 if you want to access the dashboard locally at http://localhost:8080
PORT=3000

# Remote access via Cloudflare Tunnel (optional)
# Create a named tunnel in Cloudflare Zero Trust and paste the token below.
CLOUDFLARE_TUNNEL_TOKEN=

# Storage
SNAPSHOTS_DIR=./snapshots

# Video segments (H.264 .mp4 files)
SEGMENTS_DIR=./segments
SEGMENT_DURATION_SECONDS=60
# Must match camera.fps / FRAME_SAVE_SKIP (e.g. 30 / 2 = 15)
SEGMENT_FPS=15

# Cleanup interval: how often (in hours) the cleaner runs and wipes all segments/audio/logs/snapshots
RETENTION_HOURS=12

# Audio recording (microphone / camera mic)
# To find your audio device name on Windows, run:
#   ffmpeg -list_devices true -f dshow -i dummy 2>&1
# Look for "audio" devices, e.g. "Microphone (2K Camera)"
# Leave blank to disable audio recording.
AUDIO_DEVICE=
AUDIO_DIR=./audio
AUDIO_SEGMENT_SECONDS=60
AUDIO_BITRATE=64k

# Application logs
LOGS_DIR=./logs

# Push notifications via ntfy.sh � set to your topic string, leave empty to disable.
# Create a free topic at https://ntfy.sh
NTFY_TOPIC=
